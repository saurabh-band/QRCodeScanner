<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:scanner="clr-namespace:BarcodeScanner.Mobile;assembly=BarcodeScanner.Mobile.Maui"
             x:Class="ScannerApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <scanner:CameraView VibrationOnDetected="True" HorizontalOptions="Fill" VerticalOptions="Fill"
                                OnDetected="Camera_OnDetected" ScanInterval="100" x:Name="Camera"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
